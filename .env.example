DEBUG=True
SECRET_KEY=replace-with-your-local-secret
JWT_SECRET_KEY=replace-with-your-local-jwt-secret

DB_NAME=testonline
DB_USER=testonline
DB_PASSWORD=testonline
DB_HOST=postgres
DB_PORT=5432

AZURITE_ACCOUNTS=devstoreaccount1=<your-local-azurite-key>
AZURE_BLOB_ACCOUNT_KEY=<your-local-azurite-key>
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=<your-local-azurite-key>;BlobEndpoint=http://blob:10000/devstoreaccount1;

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@testonline.local
